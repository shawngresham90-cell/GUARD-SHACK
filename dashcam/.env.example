# Required: your xAI API key (https://x.ai/api)
XAI_API_KEY=xai-...

# Models
GROK_VISION_MODEL=grok-2-vision-1212
GROK_TEXT_MODEL=grok-2-1212

# Video generation
# Default targets xAI's Grok Imagine video endpoint. If/when you have access to a
# different provider (Runway, Luma, Pika, Kling), point these at that provider
# and adjust the request body in server.js (generateVideo()).
VIDEO_API_URL=https://api.x.ai/v1/video/generations
VIDEO_API_KEY=
VIDEO_MODEL=grok-video-1
VIDEO_DURATION_SECONDS=10

# Server
PORT=3000
